{
  "expo": {
    "name": "Izba",
    "slug": "izba",
    "scheme": "izba",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "backgroundColor": "#F9F7F2",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9F7F2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pano.izba"
    },
    "android": {
      "package": "com.pano.izba",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F9F7F2"
      },
      "allowBackup": false,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "permissions": ["INTERNET"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "description": "Shared household meal planning made simple and private.",
      "themeColor": "#2D5A27",
      "backgroundColor": "#F9F7F2",
      "display": "standalone",
      "lang": "fr"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-secure-store"
    ]
  }
}
